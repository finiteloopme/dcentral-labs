# ABI Assistant Configuration
# Copy this file to .env and update with your values

# RPC Endpoints for MCP Service (points to Anvil)
ETH_RPC_URL=http://localhost:8545
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY

# Mainnet Fork URL for Anvil (used to fork mainnet state)
ANVIL_FORK_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Optional: Specific block to fork from (leave commented for latest)
# ANVIL_FORK_BLOCK=18500000

# API Keys for fetching ABIs
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY
ARBISCAN_API_KEY=YOUR_ARBISCAN_API_KEY

# Backup RPC Provider
INFURA_API_KEY=YOUR_INFURA_KEY

# Database Configuration
DATABASE_URL=sqlite://./data/abi_assistant.db

# MCP Server Configuration
MCP_HOST=0.0.0.0
MCP_PORT=3000

# Logging Configuration
# Options: trace, debug, info, warn, error
RUST_LOG=info

# Agent Network Configuration (optional)
AGENT_ID=abi-assistant-001
AGENT_NETWORK_ENABLED=false
AGENT_NETWORK_URL=

# Performance Settings
MAX_CACHE_SIZE=1000
REQUEST_TIMEOUT=30000

# Safety Settings
SIMULATION_REQUIRED=true
MAX_GAS_PRICE_GWEI=500
DEFAULT_SLIPPAGE_PERCENT=0.5