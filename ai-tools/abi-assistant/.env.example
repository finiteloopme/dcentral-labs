# ABI Assistant Configuration
# Copy this file to .env and update with your values

# ============================================
# RPC Endpoints
# ============================================
# For local development with docker-compose, ETH_RPC_URL is auto-configured to use Anvil
# Uncomment and set for production or external RPC usage

# ETH_RPC_URL=http://anvil:8545  # Auto-configured in docker-compose for local dev
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY  # For production
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY

# ============================================
# API Keys
# ============================================
# Gemini API Key (required for AI features)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# API Keys for fetching ABIs
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY
ARBISCAN_API_KEY=YOUR_ARBISCAN_API_KEY

# Backup RPC Provider
INFURA_API_KEY=YOUR_INFURA_KEY

# ============================================
# Database Configuration
# ============================================
# Auto-configured based on platform, can be overridden
# DATABASE_URL=sqlite:///data/abi_assistant.db

# ============================================
# MCP Server Configuration
# ============================================
# These are typically auto-configured but can be overridden
# MCP_HOST=0.0.0.0
# MCP_PORT=3000

# ============================================
# Logging Configuration
# ============================================
# Options: trace, debug, info, warn, error
RUST_LOG=info

# ============================================
# Anvil Configuration (Local Development)
# ============================================
# These settings are used when running Anvil via docker-compose
ANVIL_ACCOUNTS=10
ANVIL_BALANCE=10000
ANVIL_CHAIN_ID=31337
ANVIL_BLOCK_TIME=1

# Optional: Fork mainnet for testing real protocols
# ANVIL_FORK_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# ANVIL_FORK_BLOCK=latest

# ============================================
# Agent Network Configuration (optional)
# ============================================
AGENT_ID=abi-assistant-001
AGENT_NETWORK_ENABLED=false
AGENT_NETWORK_URL=

# ============================================
# Performance Settings
# ============================================
MAX_CACHE_SIZE=1000
REQUEST_TIMEOUT=30000

# ============================================
# Safety Settings
# ============================================
SIMULATION_REQUIRED=true
MAX_GAS_PRICE_GWEI=500
DEFAULT_SLIPPAGE_PERCENT=0.5

# ============================================
# Environment
# ============================================
ENVIRONMENT=development  # Options: development, staging, production