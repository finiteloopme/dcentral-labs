{
  "name": "@coding-labs/midnight-mcp",
  "version": "0.1.0",
  "description": "MCP server for Midnight Network - Compact compiler, Proof Server, and Indexer tools",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "keywords": [
    "midnight",
    "mcp",
    "model-context-protocol",
    "compact",
    "zk",
    "zero-knowledge",
    "blockchain",
    "privacy"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
