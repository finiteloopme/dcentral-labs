# Midnight MCP Server - Container Build
# Multi-stage build for smaller final image

# ==============================================================================
# Stage 1: Build
# ==============================================================================
FROM node:20-slim AS builder

WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy workspace configuration
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY tsconfig.base.json ./

# Copy midnight-mcp package (no shared dependency needed)
COPY packages/midnight-mcp ./packages/midnight-mcp

# Install dependencies
RUN pnpm install --frozen-lockfile

# Build midnight-mcp
RUN pnpm --filter @coding-labs/midnight-mcp build

# ==============================================================================
# Stage 2: Production
# ==============================================================================
FROM node:20-slim AS production

WORKDIR /app

# Install required tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    xz-utils \
    unzip \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Compact devtools v0.4.0 and download default compiler
# The installer places the binary in $HOME/.local/bin
# Then 'compact update' downloads the actual compactc compiler and sets it as default
ENV PATH="/root/.local/bin:$PATH"
RUN curl --proto '=https' --tlsv1.2 -LsSf \
    https://github.com/midnightntwrk/compact/releases/download/compact-v0.4.0/compact-installer.sh | sh \
    && compact update \
    && compact --version

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy workspace files
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./

# Copy built package
COPY --from=builder /app/packages/midnight-mcp/package.json ./packages/midnight-mcp/
COPY --from=builder /app/packages/midnight-mcp/dist ./packages/midnight-mcp/dist

# Install production dependencies only
RUN pnpm install --frozen-lockfile --prod

# Set environment
ENV NODE_ENV=production
ENV MIDNIGHT_MCP_HOST=0.0.0.0
ENV MIDNIGHT_MCP_PORT=8080
ENV MIDNIGHT_DEFAULT_NETWORK=preview

EXPOSE 8080

WORKDIR /app/packages/midnight-mcp

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD node -e "fetch('http://localhost:' + (process.env.MIDNIGHT_MCP_PORT || 8080) + '/health').then(r => r.ok ? process.exit(0) : process.exit(1)).catch(() => process.exit(1))"

CMD ["node", "dist/index.js"]
