# Midnight Agent - Container Build
# Multi-stage build for smaller final image

# ==============================================================================
# Stage 1: Build
# ==============================================================================
FROM node:20-slim AS builder

WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy workspace configuration
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY tsconfig.base.json ./

# Copy shared package
COPY packages/shared ./packages/shared

# Copy midnight-agent package
COPY packages/midnight-agent ./packages/midnight-agent

# Install dependencies
RUN pnpm install --frozen-lockfile

# Build shared package first, then midnight-agent
RUN pnpm --filter @coding-labs/shared build
RUN pnpm --filter @coding-labs/midnight-agent build

# ==============================================================================
# Stage 2: Production
# ==============================================================================
FROM node:20-slim AS production

WORKDIR /app

# Install required tools: curl, xz for extracting .tar.xz
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    xz-utils \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Compact compiler (compactc v0.29.0 - latest)
# Downloads pre-built binary for x64 Linux (musl)
ENV COMPACT_VERSION=0.4.0
RUN curl -LsSf "https://github.com/midnightntwrk/compact/releases/download/compact-v${COMPACT_VERSION}/compact-x86_64-unknown-linux-musl.tar.xz" \
    | tar -xJf - -C /usr/local/bin --strip-components=1 \
    && chmod +x /usr/local/bin/compact \
    && compact --version

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy workspace files
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./

# Copy built packages
COPY --from=builder /app/packages/shared/package.json ./packages/shared/
COPY --from=builder /app/packages/shared/dist ./packages/shared/dist

COPY --from=builder /app/packages/midnight-agent/package.json ./packages/midnight-agent/
COPY --from=builder /app/packages/midnight-agent/dist ./packages/midnight-agent/dist
COPY --from=builder /app/packages/midnight-agent/SKILLS.md ./packages/midnight-agent/

# Copy config.toml for configuration loading
COPY config.toml ./

# Install production dependencies only
RUN pnpm install --frozen-lockfile --prod

# Set environment
# Note: Cloud Run sets PORT=8080 automatically
ENV NODE_ENV=production
ENV MIDNIGHT_AGENT_HOST=0.0.0.0
ENV MIDNIGHT_AGENT_PORT=8080

EXPOSE 8080

WORKDIR /app/packages/midnight-agent

# Health check - uses PORT env var (8080 for Cloud Run, 4003 for local)
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD node -e "fetch('http://localhost:' + (process.env.PORT || 8080) + '/health').then(r => r.ok ? process.exit(0) : process.exit(1)).catch(() => process.exit(1))"

CMD ["node", "dist/index.js"]
