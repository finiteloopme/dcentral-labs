# EVM MCP Server Containerfile
#
# Includes Foundry toolchain (Anvil, Forge, Cast) for EVM development.
# This container serves as the shared toolchain for all EVM chain agents.

FROM node:22-slim AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy workspace files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY tsconfig.base.json ./
COPY packages/evm-mcp/package.json ./packages/evm-mcp/

# Install pnpm and dependencies
RUN npm install -g pnpm && \
    pnpm install --frozen-lockfile --filter @coding-labs/evm-mcp

# Copy source and build
COPY packages/evm-mcp ./packages/evm-mcp
RUN pnpm --filter @coding-labs/evm-mcp build

# --- Production image ---
FROM node:22-slim

# Install dependencies for Foundry and git (needed for forge)
RUN apt-get update && apt-get install -y \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Foundry
ENV FOUNDRY_DIR="/root/.foundry"
ENV PATH="${FOUNDRY_DIR}/bin:${PATH}"

RUN curl -L https://foundry.paradigm.xyz | bash && \
    ${FOUNDRY_DIR}/bin/foundryup

# Verify Foundry installation
RUN forge --version && cast --version && anvil --version

WORKDIR /app

# Copy built package
COPY --from=builder /app/packages/evm-mcp/dist ./dist
COPY --from=builder /app/packages/evm-mcp/package.json ./
COPY --from=builder /app/packages/evm-mcp/node_modules ./node_modules

# Create temp directory for Foundry projects
RUN mkdir -p /tmp/foundry-projects

# Environment
ENV NODE_ENV=production
ENV EVM_MCP_HOST=0.0.0.0
ENV EVM_MCP_PORT=8080
ENV ANVIL_PORT=8545

EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

CMD ["node", "dist/index.js"]
