# Agent Registry Container
# Build: podman build -t agent-registry -f packages/agent-registry/Containerfile .
# Run: podman run -p 4000:4000 -v ./config.toml:/app/config.toml:ro agent-registry

FROM node:22-slim AS base

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

WORKDIR /app

# Build stage
FROM base AS builder

# Copy workspace files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/agent-registry/package.json packages/agent-registry/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source files
COPY packages/shared/ packages/shared/
COPY packages/agent-registry/ packages/agent-registry/

# Build
RUN pnpm --filter @coding-labs/shared build
RUN pnpm --filter @coding-labs/agent-registry build

# Production stage
FROM base AS runner

WORKDIR /app

# Copy built artifacts and production dependencies
COPY --from=builder /app/package.json ./
COPY --from=builder /app/pnpm-workspace.yaml ./
COPY --from=builder /app/pnpm-lock.yaml* ./
COPY --from=builder /app/packages/shared/package.json packages/shared/
COPY --from=builder /app/packages/shared/dist packages/shared/dist/
COPY --from=builder /app/packages/agent-registry/package.json packages/agent-registry/
COPY --from=builder /app/packages/agent-registry/dist packages/agent-registry/dist/

# Install production dependencies only
RUN pnpm install --frozen-lockfile --prod

# Set environment
ENV NODE_ENV=production
ENV PORT=4000
ENV AGENT_REGISTRY_HOST=0.0.0.0

# Expose port
EXPOSE 4000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD node -e "fetch('http://localhost:' + (process.env.PORT || 4000) + '/health').then(r => r.ok ? process.exit(0) : process.exit(1)).catch(() => process.exit(1))"

# Run
CMD node packages/agent-registry/dist/index.js
