# Payment Agent Container
# Build: podman build -t payment-agent -f Containerfile .
# Run: podman run -p 4005:4005 payment-agent

FROM node:22-slim AS base

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

WORKDIR /app

# Build stage
FROM base AS builder

# Copy workspace files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/payment-agent/package.json packages/payment-agent/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source files
COPY packages/shared/ packages/shared/
COPY packages/payment-agent/ packages/payment-agent/

# Build
RUN pnpm --filter @coding-labs/shared build
RUN pnpm --filter @coding-labs/payment-agent build

# Production stage
FROM base AS runner

WORKDIR /app

# Copy built artifacts and production dependencies
COPY --from=builder /app/package.json ./
COPY --from=builder /app/pnpm-workspace.yaml ./
COPY --from=builder /app/pnpm-lock.yaml* ./
COPY --from=builder /app/packages/shared/package.json packages/shared/
COPY --from=builder /app/packages/shared/dist packages/shared/dist/
COPY --from=builder /app/packages/payment-agent/package.json packages/payment-agent/
COPY --from=builder /app/packages/payment-agent/dist packages/payment-agent/dist/
COPY --from=builder /app/packages/payment-agent/SKILLS.md packages/payment-agent/

# Install production dependencies only
RUN pnpm install --frozen-lockfile --prod

# Set environment
ENV NODE_ENV=production
# PORT is set by Cloud Run, default to 4005 for local development
ENV PORT=4005
ENV PAYMENT_AGENT_HOST=0.0.0.0

# Expose port (Cloud Run uses $PORT, default 4005 for local)
EXPOSE 4005
EXPOSE 8080

# Health check (uses PORT env var)
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD node -e "fetch('http://localhost:' + (process.env.PORT || 4005) + '/health').then(r => r.ok ? process.exit(0) : process.exit(1)).catch(() => process.exit(1))"

# Run - use shell form to allow $PORT expansion
CMD node packages/payment-agent/dist/index.js
