# Somnia Agent Container
# Build: podman build -t somnia-agent -f Containerfile .
# Run: podman run -p 4001:4001 -e GOOGLE_APPLICATION_CREDENTIALS=/creds/key.json -v ~/.config/gcloud:/creds somnia-agent

FROM node:22-slim AS base

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

WORKDIR /app

# Build stage
FROM base AS builder

# Copy workspace files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/somnia-agent/package.json packages/somnia-agent/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source files
COPY packages/shared/ packages/shared/
COPY packages/somnia-agent/ packages/somnia-agent/

# Build
RUN pnpm --filter @coding-labs/shared build
RUN pnpm --filter @coding-labs/somnia-agent build

# Production stage
FROM base AS runner

WORKDIR /app

# Copy built artifacts and production dependencies
COPY --from=builder /app/package.json ./
COPY --from=builder /app/pnpm-workspace.yaml ./
COPY --from=builder /app/pnpm-lock.yaml* ./
COPY --from=builder /app/packages/shared/package.json packages/shared/
COPY --from=builder /app/packages/shared/dist packages/shared/dist/
COPY --from=builder /app/packages/somnia-agent/package.json packages/somnia-agent/
COPY --from=builder /app/packages/somnia-agent/dist packages/somnia-agent/dist/
COPY --from=builder /app/packages/somnia-agent/SKILLS.md packages/somnia-agent/

# Install production dependencies only
RUN pnpm install --frozen-lockfile --prod

# Set environment
ENV NODE_ENV=production
ENV SOMNIA_AGENT_PORT=4001
ENV SOMNIA_AGENT_HOST=0.0.0.0

# Expose port
EXPOSE 4001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD node -e "fetch('http://localhost:4001/health').then(r => r.ok ? process.exit(0) : process.exit(1)).catch(() => process.exit(1))"

# Run
CMD ["node", "packages/somnia-agent/dist/index.js"]
