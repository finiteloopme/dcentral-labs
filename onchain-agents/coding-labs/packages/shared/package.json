{
  "name": "@coding-labs/shared",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./wallet": {
      "import": "./dist/wallet/index.js",
      "types": "./dist/wallet/index.d.ts"
    },
    "./llm": {
      "import": "./dist/llm/index.js",
      "types": "./dist/llm/index.d.ts"
    },
    "./x402": {
      "import": "./dist/x402/index.js",
      "types": "./dist/x402/index.d.ts"
    }
  },
  "scripts": {
    "dev": "pnpm exec tsc --watch",
    "build": "pnpm exec tsc",
    "clean": "rm -rf dist",
    "typecheck": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "smol-toml": "^1.3.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.8.0"
  }
}
