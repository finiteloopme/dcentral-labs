{
  "name": "coding-labs",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-agent platform for on-chain development using A2A protocol",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint packages --ext .ts",
    "lint:fix": "eslint packages --ext .ts --fix",
    "format": "prettier --write \"packages/**/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "somnia-agent": "pnpm --filter @coding-labs/somnia-agent run dev",
    "somnia-agent:build": "pnpm --filter @coding-labs/somnia-agent run build"
  },
  "keywords": [
    "a2a",
    "agents",
    "blockchain",
    "somnia",
    "web3"
  ],
  "author": "dcentral-labs",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
