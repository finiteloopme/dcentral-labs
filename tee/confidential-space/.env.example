# Local overrides for config.toml values.
# Copy this file to .env and uncomment the lines you want to override.
# Variable names match config.toml keys: SECTION_KEY (uppercased, dot replaced with underscore).
#
# GCP_PROJECT_ID=my-other-project
# GCP_REGION=us-east1
# GCP_ZONE=us-east1-b
# APP_NAME=my-app
# APP_PORT=8080
# COMPUTE_MACHINE_TYPE=n2d-standard-4
# COMPUTE_CONFIDENTIAL_TYPE=SEV
# COMPUTE_MIG_MIN_REPLICAS=1
# COMPUTE_MIG_MAX_REPLICAS=5
# DOCKER_REGISTRY=us-docker.pkg.dev
# DOCKER_REPOSITORY=my-repo
# CLOUDBUILD_SERVICE_ACCOUNT=cs-terraform
# DEPLOY_ENVIRONMENT=prod
